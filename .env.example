# AI Provider: 'groq' or 'openai'
AI_PROVIDER=groq

# Groq (free — get key at https://console.groq.com)
GROQ_API_KEY=gsk_your_groq_api_key_here

# OpenAI (optional — get key at https://platform.openai.com)
OPENAI_API_KEY=sk-your_openai_api_key_here

# Self-hosted STT (optional)
# Example URL: https://<your-cloudflared-domain>/transcribe (base URL only, no /transcribe suffix)
SELF_HOSTED_STT_URL=https://your-stt-tunnel-domain.trycloudflare.com
SELF_HOSTED_STT_KEY=your_shared_stt_key

# Supabase (get from https://supabase.com/dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Cloudinary (get from https://console.cloudinary.com)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
